{
  "name": "drop-desktop",
  "version": "1.0.1",
  "description": "Drop - Video Downloader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.drop.app",
    "productName": "Drop",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "enricovettore",
        "repo": "drop"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    },
    "win": {
      "target": "nsis"
    }
  },
  "author": "Drop",
  "license": "ISC",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-updater": "^6.8.9",
    "express": "^4.19.2"
  }
}
